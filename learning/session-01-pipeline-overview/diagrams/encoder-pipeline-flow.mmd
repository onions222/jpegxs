graph TD
    subgraph "输入"
        IMG["xs_image_t<br/>ncomps, width, height, depth<br/>comps_array 指向像素数据"]
    end

    subgraph "预处理 (xs_enc_preprocess_image)"
        PRE["Bayer 解复用<br/>mct_bayer_to_4()<br/>仅当 Cpih=TETRIX 时执行"]
    end

    subgraph "全图变换 (执行一次)"
        NLT["步骤 1: NLT 非线性变换<br/>nlt_forward_transform()<br/>文件: nlt.c (331 行)<br/>作用: DC偏移 + 信号整形"]
        MCT["步骤 2: MCT 多分量变换<br/>mct_forward_transform()<br/>文件: mct.c (516 行)<br/>作用: RCT色彩去相关"]
        DWT["步骤 3: DWT 离散小波变换<br/>dwt_forward_transform()<br/>文件: dwt.c (177 行)<br/>作用: 5/3提升小波分解"]
    end

    subgraph "Precinct 循环 (每 ph 行 × npx 列)"
        P1["步骤 4: 提取 precinct<br/>precinct_from_image()<br/>文件: precinct.c<br/>将系数按空间列分组"]
        P2["步骤 5: 计算 GCLI<br/>update_gclis()<br/>文件: precinct.c<br/>每组系数的最高有效位"]
        P3["步骤 6: 码率控制<br/>rate_control_process_precinct()<br/>文件: rate_control.c (305行)<br/>选择最优 Q, R, GCLI方法"]
        P4["步骤 7: 量化<br/>quantize_precinct()<br/>文件: quant.c (174行)<br/>根据GTLI截断比特平面"]
        P5["步骤 8: 打包<br/>pack_precinct()<br/>文件: packing.c (985行)<br/>写入 GCLI + 符号 + 数据"]
    end

    subgraph "输出"
        JXS[".jxs 码流文件<br/>符合 ISO/IEC 21122 格式"]
    end

    IMG --> PRE
    PRE --> NLT
    NLT --> MCT
    MCT --> DWT
    DWT --> P1
    P1 --> P2
    P2 --> P3
    P3 --> P4
    P4 --> P5
    P5 --> JXS

    style NLT fill:#e1f5fe
    style MCT fill:#e8f5e9
    style DWT fill:#fff3e0
    style P1 fill:#f3e5f5
    style P2 fill:#f3e5f5
    style P3 fill:#fce4ec
    style P4 fill:#fce4ec
